# BaseBadge Environment Configuration
# Copy this file to .env and fill in your actual values

# App Configuration
APP_NAME=BaseBadge
ENVIRONMENT=development
API_VERSION=v1
BACKEND_CORS_ORIGINS=["*"]

# Blockchain Configuration
BASE_NETWORK=base-mainnet
CHAIN_ID=8453

# API Keys (Get these from respective services)
# Etherscan API Key - Get from https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Alchemy API Key - Get from https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Zerion API Key - Get from https://zerion.io/
ZERION_API_KEY=your_zerion_api_key_here

# Telegram Bot Token - Get from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration (if using PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/basebadge

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379

# Optional: Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here 